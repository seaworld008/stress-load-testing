# Copy this file to scripts/servers.yaml on the control host, then edit it.
# scripts/servers.yaml is intentionally ignored by git because it may contain
# intranet IPs and passwords.

settings:
  window_start: "02:00"
  window_end: "04:00"
  slot_minutes: 15
  max_parallel_per_slot: 2
  duration_seconds: 900
  cpu_divisor: 2
  vm_workers: 1
  vm_percent: 15
  vm_min_mb: 256
  vm_max_mb: 8192

defaults:
  user: root
  port: 22
  password: "CHANGE_ME"
  enabled: true

servers:
  - name: pressure-node-01
    host: 192.0.2.11

  - name: pressure-node-02
    host: 192.0.2.12

  - name: pressure-node-03
    host: 192.0.2.13

  - name: pressure-node-04
    host: 192.0.2.14

# Per-server values override defaults:
#   password: ""      # use SSH key authentication for this host
#   password: "..."   # use a different password for this host
#   port: 2222        # use a different SSH port
#   enabled: false    # keep the host in inventory but skip deployment
